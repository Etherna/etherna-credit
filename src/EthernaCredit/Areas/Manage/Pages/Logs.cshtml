@page
@model Etherna.Credit.Areas.Manage.Pages.LogsModel
@{
    ViewData["Title"] = "Operation logs";
    ViewData["ActivePage"] = ManageNavPages.Logs;

    var pageSelectorModel = new PageSelectorModel(Model.CurrentPage, Model.MaxPage, 1);
}

<h4>@ViewData["Title"]</h4>

<div class="row">
    <div class="col-md-6">
        @foreach (var log in Model.Logs)
        {
            <div class="border-top">
                <p>
                    @switch (log)
                    {
                        case CryptoDepositOperationLog cryptoDeposit:
                            <span><b>@log.OperationName</b> - @log.CreationDateTime</span>
                            <br/>
                            <span>@cryptoDeposit.AmountCrypto @cryptoDeposit.CryptoSymbol (at ~@((log.Amount / cryptoDeposit.AmountCrypto).ToFinancialString(allowedDecimals:4, suffixSymbol: " USD/"+ cryptoDeposit.CryptoSymbol)))</span>
                            <br/>
                            break;
                        case UpdateOperationLog update:
                            <span><b>@log.OperationName</b> - @log.CreationDateTime.Date.ToShortDateString()</span>
                            <br/>
                            <span>@update.Reason</span>
                            <br/>
                            break;
                        default:
                            <span><b>@log.OperationName</b> - @log.CreationDateTime</span>
                            <br/>
                            break;
                    }
                    <span>@log.Amount.ToFinancialString(
                            allowedDecimals: null,
                            usePlusSign: true)</span>
                </p>
            </div>
        }

        <partial name="_PageSelector" model="pageSelectorModel"/>
    </div>
</div>